<!-- ==================== Joints ==================== -->

<!-- Left leg chain: base -> thigh -> shank -> wheel / idler_wheel -->
<joint name="left_thigh_joint" type="revolute">
  <origin xyz="-0.010958 -0.009778 -0.036464" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_thigh_link_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit lower="-0.4" upper="0.7" effort="2" velocity="100"/>
</joint>

<joint name="left_knee_joint" type="revolute">
  <origin xyz="-0.045962 0.0285 -0.045962" rpy="0 0 0"/>
  <parent link="left_thigh_link_1"/>
  <child link="left_shank_link_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="0.488692" lower="-0.436332" effort="2" velocity="100"/>
</joint>

<joint name="left_wheel_joint" type="continuous">
  <origin xyz="0.045962 0.002 -0.045962" rpy="0 0 0"/>
  <parent link="left_shank_link_1"/>
  <child link="left_drive_wheel_link"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <dynamics damping="0.01" friction="0.0"/>
</joint>

<joint name="left_idler_wheel_joint" type="fixed">
  <origin xyz="-0.0234 0.0025 -0.015377" rpy="0 0 0"/>
  <parent link="left_shank_link_1"/>
  <child link="left_idler_wheel_link_2"/>
</joint>

<!-- Right leg chain: base -> thigh -> shank -> wheel / idler_wheel -->
<joint name="right_thigh_joint" type="revolute">
  <origin xyz="-0.010958 -0.089778 -0.036464" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_thigh_link_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit lower="-0.4" upper="0.7" effort="2" velocity="100"/>
</joint>

<joint name="right_knee_joint" type="revolute">
  <origin xyz="-0.045962 -0.0285 -0.045962" rpy="0 0 0"/>
  <parent link="right_thigh_link_1"/>
  <child link="right_shank_link_2"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="0.488692" lower="-0.436332" effort="2" velocity="100"/>
</joint>

<joint name="right_wheel_joint" type="continuous">
  <origin xyz="0.045962 -0.002 -0.045962" rpy="0 0 0"/>
  <parent link="right_shank_link_2"/>
  <child link="right_drive_wheel_link"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <dynamics damping="0.01" friction="0.0"/>
</joint>

<joint name="right_idler_wheel_joint" type="fixed">
  <origin xyz="-0.0234 -0.0025 -0.015377" rpy="0 0 0"/>
  <parent link="right_shank_link_2"/>
  <child link="right_idler_wheel_link_1"/>
</joint>

</robot>
